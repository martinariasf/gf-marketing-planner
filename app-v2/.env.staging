# Staging environment — PocketBase enabled.
# When this variable is set, user-owned data (brief/plan/goals/learnings)
# is loaded from and saved to PocketBase instead of static JSON.
#
# Viktor-owned data (posts, suggestions, performance, approvals.log, assets)
# still comes from static files on Caddy.

VITE_PB_URL=https://staging.marketing.gfinnov.com
