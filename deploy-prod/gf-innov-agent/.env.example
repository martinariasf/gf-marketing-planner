# Example env for the gf-innov agent stack. Copy to .env, fill in, chmod 600.
# (Only the GF-19 Drive vars are documented here; the stack also needs its usual
#  secrets: OPENROUTER_API_KEY, TELEGRAM_BOT_TOKEN, TELEGRAM_ALLOWED_USERS,
#  POSTIZ_API_KEY, API_BASE, CLIENT_SLUG, API_TOKEN — see the deploy skill.)

# ── GF-19: read-only Google Drive connection ────────────────────────────────
# The single folder the client shared with this stack's service account.
# (The part of the folder URL after /folders/.)
GDRIVE_FOLDER_ID=

# The per-client service-account key. Choose ONE of the two:
#  A) Mounted file (recommended — easy rotation). Mount the key into the
#     container (see docker-compose.yml) and point at it:
GDRIVE_SA_KEY_FILE=/run/secrets/drive-sa.json
#  B) Or inline as base64 (no mount needed; passed straight through env_file):
#     GDRIVE_SA_KEY=<base64 of the service-account JSON key>

# Optional per-file read cap in MB (default 10).
# GDRIVE_MAX_READ_MB=10
