# Production inner-stack env — copy to /opt/marketing-planner/.env (chmod 600,
# NOT committed). Consumed by deploy-prod/docker-compose.yml.

# PocketBase admin (create on first mp-prod-pb boot via /_/).
PB_ADMIN_EMAIL=admin@gfinnov.com
PB_ADMIN_PASSWORD=

# Comma-separated bootstrap bearer tokens for the API. Format mirrors staging's
# BOOTSTRAP_TOKENS (dashboard/admin + per-client agent scopes). The prod agent's
# API_TOKEN must be one of these.
BOOTSTRAP_TOKENS=

# Prod Hermes agent chat gateway. Leave blank to disable in-app chat until the
# prod agent (/opt/agents/<slug>) exists. HERMES_API_KEY must equal the prod
# agent config.yaml platforms.api_server.extra.key.
HERMES_BASE_URL=http://<prod-agent-container>:8642
HERMES_API_KEY=

RELEASE=prod
LOG_LEVEL=info
