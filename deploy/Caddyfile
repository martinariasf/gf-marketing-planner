# Production Caddyfile - public hostname with TLS + per-client basic auth.
# Caddy fetches a Let's Encrypt cert on first request and auto-renews.

marketing.gfinnov.com {
    encode zstd gzip

    # API mode (full-parity cutover) -> prod inner caddy.
    # basicauth username IS the client slug; authExchange.ts scopes the token.
    handle /api/v1/auth/exchange {
        basicauth /* {
            gf-internal $2a$14$wkNG5m3H8bPLMkYXlgK0OupQTUESF4e9DF48VCRwX1saO/Bwk6sg.
            fitvibe-demo $2a$14$ET0Wl0BBviAB3LHHHVcP9uF7v3wmbof9jW5XxVGz3WL/tYBdkoD8q
        }
        reverse_proxy mp-prod-caddy:80 {
            header_up X-Forwarded-User {http.auth.user.id}
        }
    }
    @prod_api path /api/v1 /api/v1/*
    handle @prod_api {
        reverse_proxy mp-prod-caddy:80
    }
    @pb_realtime path /api/realtime /api/realtime/*
    handle @pb_realtime {
        reverse_proxy mp-prod-caddy:80
    }

    # Per-client gated data.
    # Each client has their own basicauth realm and their own credential.
    # Rotate by regenerating the bcrypt hash via:
    #   docker exec marketing-planner-caddy caddy hash-password --plaintext '<newpw>'

    handle /data/gf-internal/* {
        basicauth /* {
            gf-internal $2a$14$LY9oPBvTV62bjzWT.oOYGOvCr3YOPm/tQZvrI8hAJQO4MavB/rFQa
        }
        root * /srv/data
        uri strip_prefix /data
        file_server {
            hide .git
        }
        header Cache-Control "no-store"
    }

    handle /data/fitvibe-demo/* {
        basicauth /* {
            fitvibe-demo $2a$14$j7Ol7GgnomYyuQnArtOpWOTIPYCpb6enuZYMHzUjkTmB7coSA8MXK
        }
        root * /srv/data
        uri strip_prefix /data
        file_server {
            hide .git
        }
        header Cache-Control "no-store"
    }

    # Public client index (just slugs + names + status, no plan data).
    handle /data/index.json {
        root * /srv/data
        uri strip_prefix /data
        file_server
        header Cache-Control "no-store"
        header Access-Control-Allow-Origin "*"
    }

    # React SPA. Single-page fallback. Hashed assets get aggressive caching.
    handle {
        root * /srv/app
        try_files {path} /index.html
        file_server
        header Cache-Control "public, max-age=300, must-revalidate"
        @assets path /assets/*
        header @assets Cache-Control "public, max-age=31536000, immutable"
    }

    log {
        output stdout
        format console
    }
}

# Old Tailscale / bare-IP URLs redirect to the canonical hostname.
http://100.92.24.75, http://46.224.224.113 {
    redir https://marketing.gfinnov.com{uri} permanent
}

# ── Staging ───────────────────────────────────────────────────────────────────
# staging.marketing.gfinnov.com — Phase 1 routes /api/v1 and /api/v1/* (and Phase 6 /chat/*)
# to mp-staging-caddy, which then fans out to mp-staging-api / mp-staging-pb /
# the staging SPA. basicauth lives inside the catch-all handle so the new API
# and chat surface stay un-gated (bearer-token auth is enforced upstream).

staging.marketing.gfinnov.com {
    encode zstd gzip

    # Phase 7 basicauth→token exchange: this ONE api path requires basicauth
    # so Caddy can forward the authenticated username to mp-staging-api, which
    # mints a short-lived dash_* token tied to that user.
    # Caddy sorts handle directives by path specificity, so this matches
    # before the broader /api/v1 matcher below.
    handle /api/v1/auth/exchange {
        basicauth /* {
            staging $2a$14$fe6MgMpmwSKKKkmwd9KWoe/kh.ZFaKVU4WtIaF0wIHgMa5SBkSUhe
        }
        reverse_proxy mp-staging-caddy:80 {
            header_up X-Forwarded-User {http.auth.user.id}
        }
    }

    @staging_api path /api/v1 /api/v1/*
    handle @staging_api {
        reverse_proxy mp-staging-caddy:80
    }
    handle /chat/* {
        reverse_proxy mp-staging-caddy:80
    }

    handle {
        basicauth /* {
            staging $2a$14$fe6MgMpmwSKKKkmwd9KWoe/kh.ZFaKVU4WtIaF0wIHgMa5SBkSUhe
        }
        reverse_proxy mp-staging-caddy:80
    }

    log {
        output stdout
        format console
    }
}
