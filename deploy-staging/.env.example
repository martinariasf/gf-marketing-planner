# Staging inner-stack env — copy to /opt/marketing-planner-staging/.env (chmod
# 600, NOT committed). Consumed by deploy-staging/docker-compose.yml.

# PocketBase admin (create on first mp-staging-pb boot via /_/).
PB_ADMIN_EMAIL=admin@gfinnov.com
PB_ADMIN_PASSWORD=

# Comma-separated bootstrap bearer tokens for the API (dashboard/admin +
# per-client agent scopes).
BOOTSTRAP_TOKENS=

# Staging Hermes agent chat gateway. HERMES_API_KEY must equal the staging agent
# config.yaml platforms.api_server.extra.key.
HERMES_BASE_URL=http://hermes-marketing-staging:8642
HERMES_API_KEY=

# AES-256-GCM key for integration secrets at rest (GF-11), e.g. the Postiz API
# key entered in the dashboard. If blank, secrets are stored UNENCRYPTED (with a
# warning). Generate with: openssl rand -base64 48
INTEGRATION_SECRET_KEY=

# GF-26 scheduling port. Base URL of the Postiz PUBLIC API the scheduling
# adapter calls server-side (with the per-client key from Integrations). Defaults
# to Postiz Cloud; override for a self-hosted Postiz, e.g.
# https://postiz.example.com/public/v1
POSTIZ_API_BASE=https://api.postiz.com/public/v1

RELEASE=dev
LOG_LEVEL=info
